<!DOCTYPE html>
<html>
<head>
    <title>大阪交通導覽</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map { height: 600px; width: 100%; }
        #info { padding: 10px; background: #f4f4f4; }
    </style>
</head>
<body>
    <h2>大阪熱門景點與地鐵導覽</h2>
    <div id="map"></div>
    <div id="info">請點擊地圖上的兩個圖標以計算路徑</div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const map = L.map('map').setView([34.6937, 135.5023], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        // 這裡放入您的 locations.json 資料
        const locations = [
            { name: "大阪站 (おおさかえき)", lat: 34.7025, lng: 135.4952 },
            { name: "大阪城 (おおさかじょう)", lat: 34.6873, 135.5262 }
        ];

        let selectedPoints = [];

        locations.forEach(loc => {
            const marker = L.marker([loc.lat, loc.lng]).addTo(map);
            marker.bindPopup(loc.name);
            marker.on('click', () => {
                selectedPoints.push(loc);
                if(selectedPoints.length === 2) {
                    calculateRoute(selectedPoints[0], selectedPoints[1]);
                    selectedPoints = [];
                }
            });
        });

        function calculateRoute(p1, p2) {
            // 透過 OSRM API 獲取路徑資訊
            const url = `https://router.project-osrm.org/route/v1/transit/${p1.lng},${p1.lat};${p2.lng},${p2.lat}?overview=full`;
            fetch(url).then(res => res.json()).then(data => {
                const duration = Math.round(data.routes[0].duration / 60);
                document.getElementById('info').innerHTML = 
                    `從 ${p1.name} 到 ${p2.name} 約需 ${duration} 分鐘。`;
            });
        }
    </script>
</body>
</html>
