<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>大阪交通導覽</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map { height: 600px; width: 100%; }
        #info { padding: 15px; background: #eef; margin-top: 10px; border-radius: 5px; font-weight: bold; }
    </style>
</head>
<body>
    <h2>大阪熱門景點與地鐵導覽</h2>
    <div id="map"></div>
    <div id="info">請點擊地圖上的兩個標記來計算距離與時間。</div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const map = L.map('map').setView([34.6937, 135.5023], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // 已修正：補齊了 lng 屬性
        const locations = [
            { name: "大阪站 (おおさかえき)", lat: 34.7025, lng: 135.4952 },
            { name: "大阪城 (おおさかじょう)", lat: 34.6873, lng: 135.5262 }
        ];

        let selectedPoints = [];

        locations.forEach(loc => {
            const marker = L.marker([loc.lat, loc.lng]).addTo(map);
            marker.bindPopup(loc.name);
            marker.on('click', () => {
                selectedPoints.push(loc);
                document.getElementById('info').innerHTML = `已選取: ${selectedPoints.map(p => p.name).join(' -> ')}`;
                
                if(selectedPoints.length === 2) {
                    calculateRoute(selectedPoints[0], selectedPoints[1]);
                    selectedPoints = []; // 重置選擇
                }
            });
        });

        function calculateRoute(p1, p2) {
            // 使用 driving 模式 (因免費版 OSRM transit 支援度較低，建議先用 driving，實務上大眾運輸需串接 Google Maps API)
            const url = `https://router.project-osrm.org/route/v1/driving/${p1.lng},${p1.lat};${p2.lng},${p2.lat}?overview=false`;
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if(data.routes && data.routes.length > 0) {
                        const duration = Math.round(data.routes[0].duration / 60);
                        const distance = (data.routes[0].distance / 1000).toFixed(1);
                        document.getElementById('info').innerHTML = 
                            `從 ${p1.name} 到 ${p2.name}：<br>距離約 ${distance} 公里，開車預估需 ${duration} 分鐘。`;
                    } else {
                        document.getElementById('info').innerHTML = "無法計算路徑，請嘗試其他地點。";
                    }
                })
                .catch(err => {
                    document.getElementById('info').innerHTML = "計算失敗，請稍後再試。";
                });
        }
    </script>
</body>
</html>
